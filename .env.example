# Study Copilot Environment Variables
# Copy this file to .env and update the values

# Direct Ollama mode (bypass Supabase Edge Function)
# Set to true to call Ollama API directly from the browser.
# For Ollama Cloud: set SERVER_URL to https://ollama.com and provide API_KEY.
# For local Ollama: set SERVER_URL to http://localhost:11434 and start with CORS:
#   Windows: set OLLAMA_ORIGINS=* && ollama serve
#   macOS/Linux: OLLAMA_ORIGINS=* ollama serve
VITE_USE_DIRECT_OLLAMA=true

# Ollama server URL
# Local: http://localhost:11434
# Ollama Cloud: https://ollama.com
VITE_OLLAMA_SERVER_URL=https://ollama.com

# Ollama API Key (required for Ollama Cloud)
# Get your key from https://ollama.com/settings/keys
VITE_OLLAMA_API_KEY=your_ollama_api_key_here

# Supabase configuration (already in src/app/utils/supabase/info.tsx)
# These are committed in the codebase for the client-side SDK
# Used for auth and data persistence regardless of AI provider mode.
